        <mxCell id="ZR-NAflUI1GGsINpZlQH-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;2,2,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,0,0&quot;&gt;&lt;b data-path-to-node=&quot;2,3,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,1,0&quot;&gt;Atletas, Encarregados de Educação, Treinadores e Gerência&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,4,1,0,1&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;O sistema deve permitir ao utilizador visualizar informação detalhada e atualizada sobre o seu desempenho&amp;nbsp; &amp;nbsp;individual&lt;/span&gt;&lt;span data-path-to-node=&quot;1,4,1,0,2&quot;&gt;&lt;span class=&quot;citation-275 citation-end-275&quot;&gt;&lt;sup class=&quot;superscript&quot; data-turn-source-index=&quot;2&quot;&gt;&lt;/sup&gt;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,4,1,0,3&quot;&gt;, incluindo estatísticas de jogo, resultados em competições e avaliações registadas pela equipa&amp;nbsp; &amp;nbsp;técnica.&lt;/span&gt;" vertex="1">
          <mxGeometry height="130" width="1260" x="491" y="-340" as="geometry" />
        </mxCell>
