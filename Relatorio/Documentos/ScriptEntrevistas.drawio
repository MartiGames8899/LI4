        <mxCell id="sinojhtRkL9PFLHS1md2-1" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=left;verticalAlign=top;rounded=0;fontColor=light-dark(#000000,#000000);fontSize=29;" value="&lt;font style=&quot;color: light-dark(rgb(162, 0, 37), rgb(204, 0, 0));&quot;&gt;1.&lt;/font&gt;&amp;nbsp;&lt;span style=&quot;background-color: transparent;&quot;&gt;Sabendo que grande parte dos registos do clube são tratados de forma manual e em papel, em que situações específicas é que isso lhe causa mais perda de tempo?&lt;/span&gt;" vertex="1">
          <mxGeometry height="120" width="1070" x="400" y="-120" as="geometry" />
        </mxCell>
