@startuml casos_uso_financeira
skinparam monochrome true
skinparam shadowing false
left to right direction

actor "Gerência" as Management
actor "Encarregado\nEducação" as Parent
actor "Secretaria" as Secretary

rectangle "Subsistema: Gestão Financeira" {
    usecase "Gerar Quotas\nÉpoca" as UC_GenerateQuotas
    usecase "Obter Referência\nPagamento" as UC_GetPaymentRef
    usecase "Efetuar Pagamento" as UC_MakePayment
    usecase "Registar Pagamento\nManual" as UC_RegisterPayment
    usecase "Consultar Situação\nFinanceira" as UC_ViewFinance
    usecase "Descarregar Fatura" as UC_DownloadInvoice
    usecase "Exportar SAF-T" as UC_ExportSAFT
}

Management --> UC_GenerateQuotas
Management --> UC_ExportSAFT
Management --> UC_ViewFinance

Parent --> UC_GetPaymentRef
Parent --> UC_MakePayment
Parent --> UC_ViewFinance
Parent --> UC_DownloadInvoice

Secretary --> UC_RegisterPayment
Secretary --> UC_ViewFinance
Secretary --> UC_ExportSAFT

UC_GenerateQuotas .> UC_GetPaymentRef : nova quota
UC_MakePayment .> UC_DownloadInvoice : após confirmação
UC_RegisterPayment .> UC_DownloadInvoice : gera fatura

@enduml
