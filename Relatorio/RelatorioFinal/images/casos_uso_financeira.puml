actor "Encarregado de Educação" as EE
actor Secretaria as S

rectangle "Gestão Financeira" {
  usecase "Gerar Quotas da Época" as UC1
  usecase "Efetuar Pagamento" as UC2
  usecase "Registar Pagamento Manual" as UC3
  usecase "Gerar Relatório SAF-T" as UC4
