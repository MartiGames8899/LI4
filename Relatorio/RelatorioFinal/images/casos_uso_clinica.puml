@startuml casos_uso_clinica
skinparam monochrome true
skinparam shadowing false
left to right direction

actor "Atleta" as Athlete
actor "Encarregado\nEducação" as Parent
actor "Treinador" as Coach
actor "Secretaria" as Secretary

rectangle "Subsistema: Gestão Clínica" {
    usecase "Submeter Atestado\nMédico" as UC_SubmitMedical
    usecase "Consultar Atestados" as UC_ViewMedical
    usecase "Validar Atestado" as UC_ValidateMedical
    usecase "Registar Lesão" as UC_LogInjury
    usecase "Reportar Queixa\nFísica" as UC_ReportComplaint
    usecase "Consultar Estado\nClínico" as UC_ViewClinicalStatus
}

Athlete --> UC_SubmitMedical
Parent --> UC_SubmitMedical
Athlete --> UC_ReportComplaint
Parent --> UC_ReportComplaint

Secretary --> UC_ValidateMedical
Secretary --> UC_ViewMedical

Coach --> UC_LogInjury
Coach --> UC_ViewClinicalStatus
Coach --> UC_ConsultarAtletasInaptos

Athlete --> UC_ViewMedical
Parent --> UC_ViewMedical

UC_SubmitMedical .> UC_ValidateMedical : para validação
UC_ValidateMedical .> UC_ViewClinicalStatus : após aprovação

@enduml
