@startuml casos_uso_utilizadores
!include _cap_skin.puml
title Subsistema — Gestão de Utilizadores

left to right direction

actor Utilizador as U
actor Secretaria as S

rectangle "Gestão de Utilizadores" {
  usecase "Registar-se" as UC1
  usecase "Iniciar Sessão" as UC2
  usecase "Gerir Perfil" as UC3
  usecase "Aprovar Registo" as UC4
}

U --> UC1
U --> UC2
U --> UC3
S --> UC4

note right of UC4
  Fluxo com **estado Pendente**
  na conta até validação
  administrativa.
end note

@enduml
