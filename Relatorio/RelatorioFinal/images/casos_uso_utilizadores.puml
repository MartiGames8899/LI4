@startuml casos_uso_utilizadores
skinparam monochrome true
skinparam shadowing false
left to right direction

actor "Utilizador" as User
actor "Secretaria" as Secretary

rectangle "Subsistema: Gestão de Utilizadores" {
    usecase "Registar-se" as UC_Register
    usecase "Iniciar Sessão" as UC_Login
    usecase "Consultar Perfil" as UC_ViewProfile
    usecase "Atualizar Perfil" as UC_EditProfile
    usecase "Aprovar Pedidos\nRegistro" as UC_ApproveRegistration
    usecase "Gerir Permissões" as UC_ManagePermissions
}

User --> UC_Register
User --> UC_Login
User --> UC_ViewProfile
User --> UC_EditProfile

Secretary --> UC_ApproveRegistration
Secretary --> UC_ManagePermissions
Secretary --> UC_ViewProfile

UC_Register .> UC_Login : após aprovação
UC_Login .> UC_ViewProfile : acesso autorizado

@enduml
