@startuml casos_uso_geral
!include _cap_skin.puml

title Diagrama de casos de uso geral — agrupamento por subsistemas

left to right direction

actor "Utilizador\n(abstracto)" as U #EBF5FF
actor "Atleta" as A
actor "Treinador" as T
actor "Encarregado de Educação" as EE
actor "Secretaria" as S
actor "Gerência" as G

A -up-|> U
T -up-|> U
EE -up-|> U
S -up-|> U
G -up-|> U

rectangle "Sistema de Gestão Integrada — CAP" {
  package "Gestão de Utilizadores" {
    usecase "Autenticação e\ncontas de acesso" as UC_U
  }
  package "Gestão Desportiva" {
    usecase "Plantéis, jogos e\nconvocatórias" as UC_D
  }
  package "Gestão Clínica" {
    usecase "EMD, lesões e\nqueixas" as UC_C
  }
  package "Gestão Financeira" {
    usecase "Quotas, pagamentos\ne SAF-T" as UC_F
  }
  package "Gestão de Notificações" {
    usecase "Alertas e avisos\na utilizadores" as UC_N
  }
  package "Gestão de Instalações" {
    usecase "Reservas e agenda\nde recursos" as UC_I
  }
}

U --> UC_U
U --> UC_N

T --> UC_D
A --> UC_D
EE --> UC_D

A --> UC_C
EE --> UC_C
T --> UC_C

EE --> UC_F
S --> UC_F
G --> UC_F

T --> UC_I
S --> UC_I
G --> UC_I

S --> UC_U
G --> UC_U

@enduml
