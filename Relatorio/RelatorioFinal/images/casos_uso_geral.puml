@startuml casos_uso_geral
skinparam monochrome true
skinparam shadowing false
left to right direction

actor "Utilizador" as User
actor "Atleta" as Athlete
actor "Treinador" as Coach
actor "Encarregado\nEducação" as Parent
actor "Secretaria" as Secretary
actor "Gerência" as Management

Athlete --|> User
Coach --|> User
Parent --|> User
Secretary --|> User
Management --|> User

rectangle "Sistema de Gestão Integrada CAP" {
    package "Gestão de Utilizadores" {
        usecase "Autenticação\ne Perfil" as UC_Auth
    }
    
    package "Gestão Desportiva" {
        usecase "Plantéis,\nEventos,\nConvocatórias" as UC_Sports
    }
    
    package "Gestão Clínica" {
        usecase "Atestados,\nLesões,\nQueixas" as UC_Clinical
    }
    
    package "Gestão Financeira" {
        usecase "Quotas,\nPagamentos,\nFaturas" as UC_Finance
    }
    
    package "Gestão de Instalações" {
        usecase "Reservas\ne Eventos" as UC_Facilities
    }
    
    package "Notificações" {
        usecase "Alertas\ne Avisos" as UC_Notifications
    }
}

User --> UC_Auth
User --> UC_Notifications

Athlete --> UC_Sports
Coach --> UC_Sports
Parent --> UC_Sports

Athlete --> UC_Clinical
Parent --> UC_Clinical
Coach --> UC_Clinical

Parent --> UC_Finance
Secretary --> UC_Finance
Management --> UC_Finance

Coach --> UC_Facilities
Secretary --> UC_Facilities
Management --> UC_Facilities

Secretary --> UC_Auth
Management --> UC_Auth

@enduml
