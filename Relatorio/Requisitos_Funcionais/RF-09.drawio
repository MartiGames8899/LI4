          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;p data-path-to-node=&quot;1,5,1,0&quot;&gt;&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,5,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;O sistema deve permitir à equipa técnica criar, estruturar e guardar planos de treino detalhados (com&amp;nbsp; &amp;nbsp;exercícios, durações e intensidades), bem como partilhar ficheiros e recursos multimédia (vídeos de lances,&amp;nbsp; &amp;nbsp;esquemas táticos) numa biblioteca digital exclusiva para os atletas da sua equipa.&lt;/span&gt;&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="1260" x="491" y="-340" as="geometry" />
        </mxCell>
