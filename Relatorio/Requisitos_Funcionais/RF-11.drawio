          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;p data-path-to-node=&quot;1,5,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;O sistema deve permitir o carregamento (&lt;i data-path-to-node=&quot;1,5,1,0&quot; data-index-in-node=&quot;40&quot;&gt;upload&lt;/i&gt;) do atestado médico desportivo por parte do utilizador,&amp;nbsp; &amp;nbsp;permitindo a sua validação pela secretaria/departamento médico e gerindo automaticamente a data de validade&amp;nbsp; &amp;nbsp;do documento com a respetiva emissão de alertas.&lt;/p&gt;" vertex="1">
