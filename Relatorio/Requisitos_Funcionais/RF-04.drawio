        <mxCell id="ZR-NAflUI1GGsINpZlQH-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;2,2,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,2,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,2,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,2,1,0&quot;&gt;Comunicação e Notificações&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-460" as="geometry" />
