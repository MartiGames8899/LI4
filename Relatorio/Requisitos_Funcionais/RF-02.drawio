        <mxCell id="ZR-NAflUI1GGsINpZlQH-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;2,2,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,0,0&quot;&gt;&lt;b data-path-to-node=&quot;2,3,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,1,0&quot;&gt;Encarregado de Educação / Gerência&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;2,4,0,0&quot;&gt;&lt;b data-path-to-node=&quot;2,4,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,4,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,5,1,0&quot;&gt;O sistema deve permitir a criação de um perfil de &quot;Encarregado de Educação&quot; e a sua associação formal a&amp;nbsp; &amp;nbsp;um ou múltiplos perfis de atletas (tipicamente menores de idade), centralizando a gestão de autorizações,&amp;nbsp; &amp;nbsp;acompanhamento desportivo e responsabilidades financeiras.&lt;/span&gt;" vertex="1">
          <mxGeometry height="160" width="1260" x="491" y="-340" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Nome do Requisito" vertex="1">
