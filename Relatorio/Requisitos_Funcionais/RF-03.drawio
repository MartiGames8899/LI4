        <mxCell id="ZR-NAflUI1GGsINpZlQH-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;2,2,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,0,0&quot;&gt;&lt;b data-path-to-node=&quot;2,3,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;2,3,1,0&quot;&gt;Atletas, Encarregados de Educação, Treinadores e Gerência&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;O sistema deve disponibilizar um módulo centralizado de mensagens seguras que permita a comunicação&amp;nbsp; &amp;nbsp;direta (1-para-1) ou em grupo entre os vários intervenientes do clube, respeitando a sua estrutura hierárquica e&amp;nbsp; &amp;nbsp;desportiva." vertex="1">
          <mxGeometry height="160" width="1260" x="491" y="-340" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Nome do Requisito" vertex="1">
