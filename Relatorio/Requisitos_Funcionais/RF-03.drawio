        <mxCell id="ZR-NAflUI1GGsINpZlQH-27" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Descrição" vertex="1">
