        <mxCell id="ZR-NAflUI1GGsINpZlQH-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Análise e Desempenho" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-460" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-23" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,4,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,4,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,4,1,0&quot;&gt;Atletas / Encarregados de Educação, Treinadores e Gerência&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-400" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;p data-path-to-node=&quot;1,5,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;O sistema deve gerar painéis de visualização gráfica (dashboards) dinâmicos baseados no histórico de&amp;nbsp; &amp;nbsp;dados. Os atletas consultam o seu próprio desempenho, os treinadores acedem a comparações métricas do&amp;nbsp; &amp;nbsp;seu plantel (ex: gráficos radar) e a gerência visualiza o panorama global desportivo do clube.&lt;/p&gt;" vertex="1">
          <mxGeometry height="160" width="1260" x="491" y="-340" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-25" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Nome do Requisito" vertex="1">
          <mxGeometry height="60" width="280" x="210" y="-520" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-26" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Ator Principal" vertex="1">
          <mxGeometry height="60" width="280" x="210" y="-399" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-27" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#601414);strokeColor=light-dark(#000000,#000000);movable=1;resizable=1;rotatable=1;deletable=1;editable=1;locked=0;connectable=1;strokeWidth=3;align=center;fontColor=default;fontSize=30;" value="Descrição" vertex="1">
