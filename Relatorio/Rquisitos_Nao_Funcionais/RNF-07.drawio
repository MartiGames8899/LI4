        <mxCell id="okcL4a1NCTCaSgbpKRQO-5" parent="1" style="text;html=1;whiteSpace=wrap;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;rounded=0;fontSize=40;" value="&lt;span data-path-to-node=&quot;1,1,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,1,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,1,1,0&quot;&gt;RF-16&lt;/span&gt;" vertex="1">
