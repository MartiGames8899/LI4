        <mxCell id="okcL4a1NCTCaSgbpKRQO-6" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span style=&quot;background-color: transparent;&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,3,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,3,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,3,1,0&quot;&gt;Painéis de Desempenho (Dashboards)&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="490" y="-520" as="geometry" />
