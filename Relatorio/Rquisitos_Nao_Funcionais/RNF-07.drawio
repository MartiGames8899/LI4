        <mxCell id="ZR-NAflUI1GGsINpZlQH-21" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,2,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,2,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,2,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;Desempenho e Escalabilidade&lt;/span&gt;" vertex="1">
          <mxGeometry height="60" width="1260" x="491" y="-460" as="geometry" />
        </mxCell>
        <mxCell id="ZR-NAflUI1GGsINpZlQH-24" parent="1" style="rounded=0;whiteSpace=wrap;html=1;fillColor=light-dark(#A20025,#FFFFFF);strokeColor=light-dark(#000000,#000000);strokeWidth=3;fontColor=light-dark(#000000,#000000);align=left;verticalAlign=middle;fontSize=25;" value="&lt;span data-path-to-node=&quot;1,5,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,5,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;p data-path-to-node=&quot;1,5,1,0&quot;&gt;&lt;span data-path-to-node=&quot;1,4,0,0&quot;&gt;&lt;b data-path-to-node=&quot;1,4,0,0&quot; data-index-in-node=&quot;0&quot;&gt;&lt;/b&gt;&lt;/span&gt;&lt;span data-path-to-node=&quot;1,4,1,0&quot;&gt;&lt;span style=&quot;white-space: pre;&quot;&gt;&#x9;&lt;/span&gt;A arquitetura do sistema deve ser capaz de lidar com aumentos súbitos e significativos de tráfego sem&amp;nbsp; &amp;nbsp;degradação do serviço. Estes picos são expectáveis em momentos críticos, como o lançamento de novas&amp;nbsp; &amp;nbsp;convocatórias, períodos de renovação de inscrições ou datas limite para pagamento de quotas.&lt;/span&gt;&lt;/p&gt;" vertex="1">
